<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <SurfaceView
        android:id="@+id/surfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextView
        android:id="@+id/previewTip"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:gravity="center"
        android:text="请点击预览按钮开始预览"
        android:textSize="20sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:gravity="center"
        android:orientation="horizontal"
        android:background="#00000000">

        <ImageView
            android:id="@+id/thumbnailView"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerInside"
            android:clickable="true"
            android:src="@drawable/picture_white"
            android:background="@drawable/thumbnail_button_bg"
            android:layout_gravity="left|bottom"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btnPreview"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:text="预览"
            android:textColor="#FFFFFF"
            android:background="@drawable/button_style"/>

        <Button
            android:id="@+id/btnCapture"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:text="拍照"
            android:textColor="#FFFFFF"
            android:background="@drawable/button_style" />

        <Button
            android:id="@+id/btnRecord"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:text="录像"
            android:textColor="#FFFFFF"
            android:background="@drawable/button_style"/>

        <Button
            android:id="@+id/btnProperty"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:text="属性"
            android:textColor="#FFFFFF"
            android:background="@drawable/button_style"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/recordingLayout"
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/record_layout_bg"
        android:layout_gravity="right|top"
        android:gravity="center"
        android:layout_marginTop="10dp"
        android:layout_marginRight="10dp"
        android:visibility="gone">
        <ImageView
            android:id="@+id/recordingImage"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/recording"/>
        <TextView
            android:id="@+id/recordingText"
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            android:text="00:00"
            android:textColor="#FFF"
            android:layout_marginLeft="3dp"
            android:layout_marginRight="3dp"
            android:layout_gravity="center"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/joyfulLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="left|top"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="10dp"
        android:orientation="vertical"
        android:background="@drawable/thumbnail_button_bg"
        android:padding="6dp">

        <Button
            android:id="@+id/btnJoyfulToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Joyful Start"
            android:textColor="#FFFFFF"
            android:background="@drawable/button_style"/>

        <Button
            android:id="@+id/btnJoyfulSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Joyful 设置"
            android:textColor="#FFFFFF"
            android:background="@drawable/button_style"/>

        <TextView
            android:id="@+id/txtJoyfulStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Joyful: idle"
            android:textColor="#FFFFFF"
            android:textSize="12sp"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/seekbarLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|bottom"
        android:gravity="center"
        android:layout_marginBottom="150dp"
        android:background="@drawable/thumbnail_button_bg"
        android:padding="10dp"
        android:visibility="gone"
        android:orientation="vertical">

        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:minHeight="3dp"
            android:maxHeight="3dp"
            android:progressDrawable="@drawable/seekbar_body"
            android:thumb="@drawable/seekbar_thumb"/>
        <TextView
            android:id="@+id/seekBarText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="0"
            android:textSize="12sp"
            android:textColor="#FFF"
            android:gravity="center"/>
    </LinearLayout>
</FrameLayout>
