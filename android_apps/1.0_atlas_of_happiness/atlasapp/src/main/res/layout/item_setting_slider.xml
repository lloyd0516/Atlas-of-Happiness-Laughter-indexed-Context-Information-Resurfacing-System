<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/atlas_section_bg"
    android:orientation="vertical"
    android:padding="14dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
        <TextView android:id="@+id/txtLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="@color/atlas_text_primary" android:textStyle="bold" />
        <TextView android:id="@+id/txtValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/atlas_text_primary" />
    </LinearLayout>
    <TextView android:id="@+id/txtDesc" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textColor="@color/atlas_text_secondary" android:textSize="12sp" />
    <SeekBar android:id="@+id/seekBar" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" />
</LinearLayout>
