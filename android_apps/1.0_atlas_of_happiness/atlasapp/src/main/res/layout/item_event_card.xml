<?xml version="1.0" encoding="utf-8"?>
<android.support.v7.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="1dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/atlas_gradient_card" android:gravity="center_vertical" android:orientation="horizontal" android:padding="16dp">
        <ImageView android:id="@+id/imgEventIcon" android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/atlas_chip_selected" android:padding="8dp" android:src="@drawable/ic_atlas_event" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginLeft="12dp" android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/txtEventTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/atlas_text_secondary" android:textSize="13sp" />
            <TextView android:id="@+id/txtEventBody" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textColor="@color/atlas_text_primary" android:textSize="17sp" android:textStyle="bold" />
            <TextView android:id="@+id/txtEventMeta" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:textColor="@color/atlas_text_secondary" android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</android.support.v7.widget.CardView>
