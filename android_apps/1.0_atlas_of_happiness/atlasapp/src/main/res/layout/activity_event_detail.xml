<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/atlas_background">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
            <Button android:id="@+id/btnBack" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/atlas_chip" android:text="@string/btn_back" android:textAllCaps="false" android:textColor="@color/atlas_text_primary" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="12dp" android:text="@string/event_detail_title" android:textColor="@color/atlas_text_primary" android:textSize="22sp" android:textStyle="bold" />
        </LinearLayout>
        <TextView android:id="@+id/txtHeaderTime" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:textColor="@color/atlas_text_secondary" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="@string/event_detail_timeline" android:textColor="@color/atlas_text_primary" android:textStyle="bold" />
        <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:scrollbars="none"><LinearLayout android:id="@+id/timelineContainer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" /></HorizontalScrollView>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="@string/event_detail_auto" android:textColor="@color/atlas_text_primary" android:textStyle="bold" />
        <ImageView android:id="@+id/imagePreview" android:layout_width="match_parent" android:layout_height="220dp" android:layout_marginTop="10dp" android:background="@drawable/atlas_section_bg" android:scaleType="centerCrop" android:visibility="gone" />
        <VideoView android:id="@+id/videoPreview" android:layout_width="match_parent" android:layout_height="220dp" android:layout_marginTop="10dp" android:background="@drawable/atlas_section_bg" android:visibility="gone" />
        <TextView android:id="@+id/txtAudioStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:textColor="@color/atlas_text_secondary" />
        <LinearLayout android:id="@+id/autoMediaContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:orientation="vertical" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="@string/event_detail_context" android:textColor="@color/atlas_text_primary" android:textStyle="bold" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="@string/label_location" android:textColor="@color/atlas_text_secondary" />
        <TextView android:id="@+id/txtGps" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:background="@drawable/atlas_section_bg" android:padding="12dp" android:textColor="@color/atlas_text_primary" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="@string/label_weather" android:textColor="@color/atlas_text_secondary" />
        <TextView android:id="@+id/txtWeather" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:background="@drawable/atlas_section_bg" android:padding="12dp" android:textColor="@color/atlas_text_primary" />
        <Button android:id="@+id/btnRefreshContext" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="10dp" android:background="@drawable/atlas_button_soft" android:text="@string/btn_refresh" android:textAllCaps="false" android:textColor="@color/atlas_text_primary" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="@string/event_detail_reflection" android:textColor="@color/atlas_text_primary" android:textStyle="bold" />
        <EditText android:id="@+id/inputNote" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/atlas_section_bg" android:gravity="top" android:hint="@string/event_detail_notes_hint" android:minHeight="100dp" android:padding="12dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:orientation="horizontal">
            <Button android:id="@+id/btnAddText" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:background="@drawable/atlas_button_soft" android:text="@string/btn_text_note" android:textAllCaps="false" android:textColor="@color/atlas_text_primary" />
            <Button android:id="@+id/btnAddAudio" android:layout_width="0dp" android:layout_height="48dp" android:layout_marginLeft="8dp" android:layout_weight="1" android:background="@drawable/atlas_button_soft" android:text="@string/btn_audio_note" android:textAllCaps="false" android:textColor="@color/atlas_text_primary" />
            <Button android:id="@+id/btnAddPhoto" android:layout_width="0dp" android:layout_height="48dp" android:layout_marginLeft="8dp" android:layout_weight="1" android:background="@drawable/atlas_button_soft" android:text="@string/btn_photo_note" android:textAllCaps="false" android:textColor="@color/atlas_text_primary" />
        </LinearLayout>
        <LinearLayout android:id="@+id/notesContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="vertical" />
        <LinearLayout android:id="@+id/userMediaContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="vertical" />
    </LinearLayout>
</ScrollView>
