<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/atlas_background">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
            <Button android:id="@+id/btnBack" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/atlas_chip" android:text="@string/btn_back" android:textAllCaps="false" android:textColor="@color/atlas_text_primary" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="12dp" android:text="@string/settings_title" android:textColor="@color/atlas_text_primary" android:textSize="24sp" android:textStyle="bold" />
        </LinearLayout>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/settings_subtitle" android:textColor="@color/atlas_text_secondary" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="@string/settings_detection_preset" android:textColor="@color/atlas_text_primary" android:textSize="18sp" android:textStyle="bold" />

        <android.support.v7.widget.CardView android:id="@+id/cardPresetFrequent" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" app:cardCornerRadius="16dp" app:cardElevation="1dp"><LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/atlas_gradient_card" android:orientation="vertical" android:padding="16dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/level_frequent" android:textColor="@color/atlas_text_primary" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="@string/caption_frequent" android:textColor="@color/atlas_text_secondary" /></LinearLayout></android.support.v7.widget.CardView>
        <android.support.v7.widget.CardView android:id="@+id/cardPresetMedium" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" app:cardCornerRadius="16dp" app:cardElevation="1dp"><LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/atlas_gradient_card" android:orientation="vertical" android:padding="16dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/level_medium" android:textColor="@color/atlas_text_primary" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="@string/caption_medium" android:textColor="@color/atlas_text_secondary" /></LinearLayout></android.support.v7.widget.CardView>
        <android.support.v7.widget.CardView android:id="@+id/cardPresetSparse" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" app:cardCornerRadius="16dp" app:cardElevation="1dp"><LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/atlas_gradient_card" android:orientation="vertical" android:padding="16dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/level_sparse" android:textColor="@color/atlas_text_primary" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="@string/caption_sparse" android:textColor="@color/atlas_text_secondary" /></LinearLayout></android.support.v7.widget.CardView>
        <android.support.v7.widget.CardView android:id="@+id/cardPresetCustom" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" app:cardCornerRadius="16dp" app:cardElevation="1dp"><LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/atlas_gradient_card" android:orientation="vertical" android:padding="16dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/level_custom" android:textColor="@color/atlas_text_primary" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="@string/caption_custom" android:textColor="@color/atlas_text_secondary" /></LinearLayout></android.support.v7.widget.CardView>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:text="@string/settings_custom" android:textColor="@color/atlas_text_primary" android:textSize="18sp" android:textStyle="bold" />
        <LinearLayout android:id="@+id/sliderContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:orientation="vertical" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="@string/config_language" android:textColor="@color/atlas_text_primary" />
        <EditText android:id="@+id/inputSpeechLanguage" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/atlas_section_bg" android:padding="12dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="@string/config_operating_point" android:textColor="@color/atlas_text_primary" />
        <EditText android:id="@+id/inputOperatingPoint" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/atlas_section_bg" android:padding="12dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="@string/config_output_root" android:textColor="@color/atlas_text_primary" />
        <EditText android:id="@+id/inputOutputRoot" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/atlas_section_bg" android:padding="12dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="@string/settings_speechmatics_key" android:textColor="@color/atlas_text_primary" />
        <EditText android:id="@+id/inputSpeechmaticsKey" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/atlas_section_bg" android:padding="12dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="@string/settings_speechmatics_rt_url" android:textColor="@color/atlas_text_primary" />
        <EditText android:id="@+id/inputSpeechmaticsRtUrl" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/atlas_section_bg" android:padding="12dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="@string/settings_language" android:textColor="@color/atlas_text_primary" android:textStyle="bold" />
        <RadioGroup android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="vertical">
            <RadioButton android:id="@+id/radioLangSystem" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/settings_language_follow" android:textColor="@color/atlas_text_primary" />
            <RadioButton android:id="@+id/radioLangEn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/settings_language_en" android:textColor="@color/atlas_text_primary" />
            <RadioButton android:id="@+id/radioLangZh" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/settings_language_zh" android:textColor="@color/atlas_text_primary" />
        </RadioGroup>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="@string/settings_api" android:textColor="@color/atlas_text_primary" android:textStyle="bold" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="@string/settings_api_caption" android:textColor="@color/atlas_text_secondary" />
        <TextView android:id="@+id/txtMapsKeyHint" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/atlas_section_bg" android:padding="12dp" android:text="@string/settings_google_maps_key_needed" android:textColor="@color/atlas_text_secondary" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="@string/settings_google_weather_key" android:textColor="@color/atlas_text_primary" />
        <EditText android:id="@+id/inputGoogleWeatherKey" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/atlas_section_bg" android:padding="12dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="@string/settings_output_path" android:textColor="@color/atlas_text_primary" />
        <TextView android:id="@+id/txtOutputPath" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textColor="@color/atlas_text_secondary" />
        <Button android:id="@+id/btnOpenLogs" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="20dp" android:background="@drawable/atlas_button_soft" android:text="@string/settings_logs" android:textAllCaps="false" android:textColor="@color/atlas_text_primary" />
        <Button android:id="@+id/btnSave" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="12dp" android:background="@drawable/atlas_button_soft" android:text="@string/btn_save" android:textAllCaps="false" android:textColor="@color/atlas_text_primary" />
    </LinearLayout>
</ScrollView>
