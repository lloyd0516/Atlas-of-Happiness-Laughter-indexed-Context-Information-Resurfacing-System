<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/atlas_secondary" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/atlas_surface" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="@color/atlas_divider" />
        </shape>
    </item>
</selector>
